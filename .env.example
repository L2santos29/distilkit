# ═══════════════════════════════════════════════════════════════
# DistilKit — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and adjust values as needed.
#   cp .env.example .env
#
# All variables are OPTIONAL — the application works with the
# defaults shown below.
# ═══════════════════════════════════════════════════════════════

# ── Device ─────────────────────────────────────────────────────
# Target device for training/inference.
# Choices: cpu, cuda, npu
# DEVICE=cpu

# ── Server ─────────────────────────────────────────────────────
# Host address to bind the web GUI / API server.
# Use 0.0.0.0 to accept connections from other machines.
# HOST=127.0.0.1
#
# Port for the web GUI / API server.
# PORT=7860
#
# Set to "true" to run in API-only mode (no frontend).
# API_ONLY=false

# ── Paths ──────────────────────────────────────────────────────
# Where completed training runs are persisted (as JSON files).
# RUNS_DIR=runs
#
# Where downloaded datasets are cached.
# DATA_DIR=./data
#
# Where exported models and training checkpoints are saved.
# CHECKPOINTS_DIR=checkpoints

# ── Logging ────────────────────────────────────────────────────
# Maximum characters kept in the in-memory training log buffer.
# Older entries are trimmed to prevent UI slowdown on long runs.
# MAX_LOG_SIZE=100000
#
# Logging verbosity.
# Choices: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
